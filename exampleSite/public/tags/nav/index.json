  "content":     "\u003cp\u003eThe footer sits at the bottom of every page via \u003ccode\u003epartials/body/footer.html\u003c/code\u003e.\nCopyright on the left, social links on the right, separated by \u003ccode\u003e|\u003c/code\u003e.\u003c/p\u003e\n\u003ch2 id=\"default\"\u003eDefault\u003c/h2\u003e\n\u003cfooter class=\"site-footer\" style=\"margin: 1rem 0; position: static;\"\u003e\n  \u003cdiv class=\"site-footer__left\"\u003e\u0026copy; 2025 Site Title\u003c/div\u003e\n  \u003cdiv class=\"site-footer__right\"\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"site-footer__link-text\"\u003eGitHub\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"site-footer__link-text\"\u003eLinkedIn\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"site-footer__link-text\"\u003eRSS\u003c/span\u003e\u003c/a\u003e\n  \u003c/div\u003e\n\u003c/footer\u003e\n\u003ch2 id=\"with-icons\"\u003eWith icons\u003c/h2\u003e\n\u003cp\u003eEach link can carry a glyph from \u003ccode\u003edata/icons.yaml\u003c/code\u003e. Below 768px the\ntext hides, leaving icon-only links.\u003c/p\u003e\n\u003cfooter class=\"site-footer\" style=\"margin: 1rem 0; position: static;\"\u003e\n  \u003cdiv class=\"site-footer__left\"\u003e\u0026copy; 2025 Your Brand\u003c/div\u003e\n  \u003cdiv class=\"site-footer__right\"\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf09b;\u003c/span\u003e\u003cspan class=\"site-footer__link-text\"\u003eGitHub\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf099;\u003c/span\u003e\u003cspan class=\"site-footer__link-text\"\u003eTwitter\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf0e0;\u003c/span\u003e\u003cspan class=\"site-footer__link-text\"\u003eEmail\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf09e;\u003c/span\u003e\u003cspan class=\"site-footer__link-text\"\u003eRSS\u003c/span\u003e\u003c/a\u003e\n  \u003c/div\u003e\n\u003c/footer\u003e\n\u003ch2 id=\"icons-only\"\u003eIcons only\u003c/h2\u003e\n\u003cp\u003eDrop the link text for a compact row of glyphs.\u003c/p\u003e\n\u003cfooter class=\"site-footer\" style=\"margin: 1rem 0; position: static;\"\u003e\n  \u003cdiv class=\"site-footer__left\"\u003e\u0026copy; 2025 Portfolio\u003c/div\u003e\n  \u003cdiv class=\"site-footer__right\"\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf09b;\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf08c;\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf0e0;\u003c/span\u003e\u003c/a\u003e\n    \u003cspan class=\"site-footer__sep\"\u003e|\u003c/span\u003e\n    \u003ca href=\"#\"\u003e\u003cspan class=\"icon\" aria-hidden=\"true\"\u003e\u0026#xf09e;\u003c/span\u003e\u003c/a\u003e\n  \u003c/div\u003e\n\u003c/footer\u003e\n\u003ch2 id=\"config\"\u003eConfig\u003c/h2\u003e\n\u003cp\u003eLinks come from \u003ccode\u003eparams.social\u003c/code\u003e in \u003ccode\u003ehugo.toml\u003c/code\u003e:\u003c/p\u003e\n\u003cdiv class=\"highlight\"\u003e\u003cpre tabindex=\"0\" class=\"chroma\"\u003e\u003ccode class=\"language-toml\" data-lang=\"toml\"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003eparams\u003c/span\u003e\u003cspan class=\"p\"\u003e]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nx\"\u003ecopyright\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;\u0026amp;copy; 2025 tui demo\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e[[\u003c/span\u003e\u003cspan class=\"nx\"\u003eparams\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003esocial\u003c/span\u003e\u003cspan class=\"p\"\u003e]]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003ename\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;GitHub\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eurl\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;https://github.com/user\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eicon\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;github\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e[[\u003c/span\u003e\u003cspan class=\"nx\"\u003eparams\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003esocial\u003c/span\u003e\u003cspan class=\"p\"\u003e]]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003ename\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;RSS\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eurl\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;/index.xml\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eicon\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;rss\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e\u003cp\u003eExternal URLs open in a new tab; internal URLs (starting with \u003ccode\u003e/\u003c/code\u003e)\nstay in-page. Omit \u003ccode\u003ecopyright\u003c/code\u003e to default to \u003ccode\u003e© {year} {site.Title}\u003c/code\u003e.\u003c/p\u003e\n"
