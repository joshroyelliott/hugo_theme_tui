  "summary":     "Nerd Font glyphs looked up by name from a single data file.",
  "readingTime": 1,
  "content":     "\u003cp\u003eIcons are Nerd Font glyphs mapped in \u003ccode\u003edata/icons.yaml\u003c/code\u003e. The theme ships\na default set; override by placing your own \u003ccode\u003edata/icons.yaml\u003c/code\u003e in the\nsite root.\u003c/p\u003e\n\u003ch2 id=\"usage\"\u003eUsage\u003c/h2\u003e\n\u003cdiv class=\"highlight\"\u003e\u003cpre tabindex=\"0\" class=\"chroma\"\u003e\u003ccode class=\"language-go-html-template\" data-lang=\"go-html-template\"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"cp\"\u003e{{\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"nx\"\u003epartial\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;icon.html\u0026#34;\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;github\u0026#34;\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"cp\"\u003e}}\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"cp\"\u003e{{\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"nx\"\u003epartial\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;icon.html\u0026#34;\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e(\u003c/span\u003e\u003cspan class=\"nx\"\u003edict\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;name\u0026#34;\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;search\u0026#34;\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;class\u0026#34;\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;icon--lg\u0026#34;\u003c/span\u003e\u003cspan class=\"o\"\u003e)\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"cp\"\u003e}}\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e\u003cp\u003eUnknown names render as the raw codepoint, so you can also pass a\nliteral hex value.\u003c/p\u003e\n\u003ch2 id=\"available-glyphs\"\u003eAvailable glyphs\u003c/h2\u003e\n\n\u003cdiv class=\"icon-grid\"\u003e\u003cdiv class=\"icon-grid__cell\" title=\"arrow-left: U+F060\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"arrow-left\"\u003e\u0026#xf060;\u003c/span\u003e\n\n      \u003ccode\u003earrow-left\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"arrow-right: U+F061\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"arrow-right\"\u003e\u0026#xf061;\u003c/span\u003e\n\n      \u003ccode\u003earrow-right\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"bars: U+F0C9\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"bars\"\u003e\u0026#xf0c9;\u003c/span\u003e\n\n      \u003ccode\u003ebars\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"book: U+F02D\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"book\"\u003e\u0026#xf02d;\u003c/span\u003e\n\n      \u003ccode\u003ebook\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"bookmark: U+F02E\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"bookmark\"\u003e\u0026#xf02e;\u003c/span\u003e\n\n      \u003ccode\u003ebookmark\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"calendar: U+F133\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"calendar\"\u003e\u0026#xf133;\u003c/span\u003e\n\n      \u003ccode\u003ecalendar\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"chevron-down: U+F078\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"chevron-down\"\u003e\u0026#xf078;\u003c/span\u003e\n\n      \u003ccode\u003echevron-down\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"chevron-left: U+F053\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"chevron-left\"\u003e\u0026#xf053;\u003c/span\u003e\n\n      \u003ccode\u003echevron-left\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"chevron-right: U+F054\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"chevron-right\"\u003e\u0026#xf054;\u003c/span\u003e\n\n      \u003ccode\u003echevron-right\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"chevron-up: U+F077\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"chevron-up\"\u003e\u0026#xf077;\u003c/span\u003e\n\n      \u003ccode\u003echevron-up\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"clock: U+F017\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"clock\"\u003e\u0026#xf017;\u003c/span\u003e\n\n      \u003ccode\u003eclock\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"code: U+F121\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"code\"\u003e\u0026#xf121;\u003c/span\u003e\n\n      \u003ccode\u003ecode\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"cog: U+F013\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"cog\"\u003e\u0026#xf013;\u003c/span\u003e\n\n      \u003ccode\u003ecog\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"comment: U+F075\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"comment\"\u003e\u0026#xf075;\u003c/span\u003e\n\n      \u003ccode\u003ecomment\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"css: U+E749\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"css\"\u003e\u0026#xe749;\u003c/span\u003e\n\n      \u003ccode\u003ecss\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"document: U+F15C\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"document\"\u003e\u0026#xf15c;\u003c/span\u003e\n\n      \u003ccode\u003edocument\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"download: U+F019\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"download\"\u003e\u0026#xf019;\u003c/span\u003e\n\n      \u003ccode\u003edownload\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"email: U+F0E0\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"email\"\u003e\u0026#xf0e0;\u003c/span\u003e\n\n      \u003ccode\u003eemail\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"error: U+F06A\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"error\"\u003e\u0026#xf06a;\u003c/span\u003e\n\n      \u003ccode\u003eerror\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"external-link: U+F08E\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"external-link\"\u003e\u0026#xf08e;\u003c/span\u003e\n\n      \u003ccode\u003eexternal-link\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"file: U+F15B\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"file\"\u003e\u0026#xf15b;\u003c/span\u003e\n\n      \u003ccode\u003efile\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"folder: U+F07B\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"folder\"\u003e\u0026#xf07b;\u003c/span\u003e\n\n      \u003ccode\u003efolder\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"github: U+F09B\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"github\"\u003e\u0026#xf09b;\u003c/span\u003e\n\n      \u003ccode\u003egithub\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"gitlab: U+F296\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"gitlab\"\u003e\u0026#xf296;\u003c/span\u003e\n\n      \u003ccode\u003egitlab\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"go: U+E627\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"go\"\u003e\u0026#xe627;\u003c/span\u003e\n\n      \u003ccode\u003ego\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"heart: U+F004\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"heart\"\u003e\u0026#xf004;\u003c/span\u003e\n\n      \u003ccode\u003eheart\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"home: U+F015\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"home\"\u003e\u0026#xf015;\u003c/span\u003e\n\n      \u003ccode\u003ehome\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"html: U+E736\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"html\"\u003e\u0026#xe736;\u003c/span\u003e\n\n      \u003ccode\u003ehtml\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"info: U+F129\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"info\"\u003e\u0026#xf129;\u003c/span\u003e\n\n      \u003ccode\u003einfo\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"java: U+E738\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"java\"\u003e\u0026#xe738;\u003c/span\u003e\n\n      \u003ccode\u003ejava\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"javascript: U+E74E\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"javascript\"\u003e\u0026#xe74e;\u003c/span\u003e\n\n      \u003ccode\u003ejavascript\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"link: U+F0C1\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"link\"\u003e\u0026#xf0c1;\u003c/span\u003e\n\n      \u003ccode\u003elink\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"linkedin: U+F08C\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"linkedin\"\u003e\u0026#xf08c;\u003c/span\u003e\n\n      \u003ccode\u003elinkedin\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"lua: U+E620\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"lua\"\u003e\u0026#xe620;\u003c/span\u003e\n\n      \u003ccode\u003elua\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"mastodon: U+F4F6\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"mastodon\"\u003e\u0026#xf4f6;\u003c/span\u003e\n\n      \u003ccode\u003emastodon\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"phone: U+F095\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"phone\"\u003e\u0026#xf095;\u003c/span\u003e\n\n      \u003ccode\u003ephone\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"privacy: U+F21B\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"privacy\"\u003e\u0026#xf21b;\u003c/span\u003e\n\n      \u003ccode\u003eprivacy\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"python: U+E73C\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"python\"\u003e\u0026#xe73c;\u003c/span\u003e\n\n      \u003ccode\u003epython\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"rss: U+F09E\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"rss\"\u003e\u0026#xf09e;\u003c/span\u003e\n\n      \u003ccode\u003erss\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"ruby: U+E739\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"ruby\"\u003e\u0026#xe739;\u003c/span\u003e\n\n      \u003ccode\u003eruby\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"rust: U+E7A8\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"rust\"\u003e\u0026#xe7a8;\u003c/span\u003e\n\n      \u003ccode\u003erust\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"search: U+F002\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"search\"\u003e\u0026#xf002;\u003c/span\u003e\n\n      \u003ccode\u003esearch\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"star: U+F005\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"star\"\u003e\u0026#xf005;\u003c/span\u003e\n\n      \u003ccode\u003estar\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"success: U+F058\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"success\"\u003e\u0026#xf058;\u003c/span\u003e\n\n      \u003ccode\u003esuccess\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"tag: U+F02B\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"tag\"\u003e\u0026#xf02b;\u003c/span\u003e\n\n      \u003ccode\u003etag\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"tags: U+F02C\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"tags\"\u003e\u0026#xf02c;\u003c/span\u003e\n\n      \u003ccode\u003etags\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"terminal: U+F120\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"terminal\"\u003e\u0026#xf120;\u003c/span\u003e\n\n      \u003ccode\u003eterminal\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"twitter: U+F099\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"twitter\"\u003e\u0026#xf099;\u003c/span\u003e\n\n      \u003ccode\u003etwitter\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"typescript: U+E628\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"typescript\"\u003e\u0026#xe628;\u003c/span\u003e\n\n      \u003ccode\u003etypescript\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"upload: U+F093\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"upload\"\u003e\u0026#xf093;\u003c/span\u003e\n\n      \u003ccode\u003eupload\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"user: U+F007\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"user\"\u003e\u0026#xf007;\u003c/span\u003e\n\n      \u003ccode\u003euser\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"users: U+F0C0\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"users\"\u003e\u0026#xf0c0;\u003c/span\u003e\n\n      \u003ccode\u003eusers\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"warning: U+F071\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"warning\"\u003e\u0026#xf071;\u003c/span\u003e\n\n      \u003ccode\u003ewarning\u003c/code\u003e\n    \u003c/div\u003e\u003c/div\u003e\n\n\u003ch2 id=\"adding-icons\"\u003eAdding icons\u003c/h2\u003e\n\u003cp\u003eAdd entries to \u003ccode\u003edata/icons.yaml\u003c/code\u003e as \u003ccode\u003ename: codepoint\u003c/code\u003e pairs:\u003c/p\u003e\n\u003cdiv class=\"highlight\"\u003e\u003cpre tabindex=\"0\" class=\"chroma\"\u003e\u003ccode class=\"language-yaml\" data-lang=\"yaml\"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nt\"\u003edocker\u003c/span\u003e\u003cspan class=\"p\"\u003e:\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"l\"\u003ef308\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nt\"\u003ekubernetes\u003c/span\u003e\u003cspan class=\"p\"\u003e:\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"l\"\u003efd31\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e\u003cp\u003eCodepoints are hex without a \u003ccode\u003e0x\u003c/code\u003e prefix. Browse available glyphs at\n\u003ca href=\"https://www.nerdfonts.com/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003enerdfonts.com/cheat-sheet\u003c/a\u003e\n.\u003c/p\u003e\n"
},
