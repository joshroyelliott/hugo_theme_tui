terminal\"\u003e\u0026#xf120;\u003c/span\u003e\n\n      \u003ccode\u003eterminal\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"twitter: U+F099\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"twitter\"\u003e\u0026#xf099;\u003c/span\u003e\n\n      \u003ccode\u003etwitter\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"typescript: U+E628\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"typescript\"\u003e\u0026#xe628;\u003c/span\u003e\n\n      \u003ccode\u003etypescript\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"upload: U+F093\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"upload\"\u003e\u0026#xf093;\u003c/span\u003e\n\n      \u003ccode\u003eupload\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"user: U+F007\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"user\"\u003e\u0026#xf007;\u003c/span\u003e\n\n      \u003ccode\u003euser\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"users: U+F0C0\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"users\"\u003e\u0026#xf0c0;\u003c/span\u003e\n\n      \u003ccode\u003eusers\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"warning: U+F071\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"warning\"\u003e\u0026#xf071;\u003c/span\u003e\n\n      \u003ccode\u003ewarning\u003c/code\u003e\n    \u003c/div\u003e\u003c/div\u003e\n\n\u003ch2 id=\"adding-icons\"\u003eAdding icons\u003c/h2\u003e\n\u003cp\u003eAdd entries to \u003ccode\u003edata/icons.yaml\u003c/code\u003e as \u003ccode\u003ename: codepoint\u003c/code\u003e pairs:\u003c/p\u003e\n\u003cdiv class=\"highlight\"\u003e\u003cpre tabindex=\"0\" class=\"chroma\"\u003e\u003ccode class=\"language-yaml\" data-lang=\"yaml\"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nt\"\u003edocker\u003c/span\u003e\u003cspan class=\"p\"\u003e:\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"l\"\u003ef308\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nt\"\u003ekubernetes\u003c/span\u003e\u003cspan class=\"p\"\u003e:\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"l\"\u003efd31\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e\u003cp\u003eCodepoints are hex without a \u003ccode\u003e0x\u003c/code\u003e prefix. Browse available glyphs at\n\u003ca href=\"https://www.nerdfonts.com/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003enerdfonts.com/cheat-sheet\u003c/a\u003e\n.\u003c/p\u003e\n"
}
