  "readingTime": 1,
  "content":     "\u003cp\u003eA flex row of \u003ccode\u003eclip-path\u003c/code\u003e chevron shapes. Title tab on the left, menu\npills on the right. No JavaScript.\u003c/p\u003e\n\u003ch2 id=\"plain\"\u003ePlain\u003c/h2\u003e\n\u003cnav class=\"site-nav\" aria-label=\"Plain nav demo\" style=\"margin: 1rem 0;\"\u003e\n  \u003cdiv class=\"site-nav__inner\"\u003e\n    \u003ca href=\"#\" class=\"site-nav__title\"\u003e\u003cspan class=\"site-nav__title-text\"\u003eTitle\u003c/span\u003e\u003c/a\u003e\n    \u003cul class=\"site-nav__menu\"\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eHome\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eBlog\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eAbout\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n    \u003c/ul\u003e\n  \u003c/div\u003e\n\u003c/nav\u003e\n\u003ch2 id=\"with-icons\"\u003eWith icons\u003c/h2\u003e\n\u003cp\u003eTitle icon from \u003ccode\u003esite.Params.titleIcon\u003c/code\u003e; link icons from each menu\nentry\u0026rsquo;s \u003ccode\u003eparams.icon\u003c/code\u003e.\u003c/p\u003e\n\u003cnav class=\"site-nav\" aria-label=\"Icon nav demo\" style=\"margin: 1rem 0;\"\u003e\n  \u003cdiv class=\"site-nav__inner\"\u003e\n    \u003ca href=\"#\" class=\"site-nav__title\"\u003e\n      \u003cspan class=\"icon site-nav__icon\" aria-hidden=\"true\"\u003e\u0026#xf120;\u003c/span\u003e\n      \u003cspan class=\"site-nav__title-text\"\u003etui\u003c/span\u003e\n    \u003c/a\u003e\n    \u003cul class=\"site-nav__menu\"\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"icon site-nav__icon\" aria-hidden=\"true\"\u003e\u0026#xf015;\u003c/span\u003e\u003cspan class=\"site-nav__link-text\"\u003eHome\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"icon site-nav__icon\" aria-hidden=\"true\"\u003e\u0026#xf15c;\u003c/span\u003e\u003cspan class=\"site-nav__link-text\"\u003eBlog\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"icon site-nav__icon\" aria-hidden=\"true\"\u003e\u0026#xf07b;\u003c/span\u003e\u003cspan class=\"site-nav__link-text\"\u003eProjects\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"icon site-nav__icon\" aria-hidden=\"true\"\u003e\u0026#xf007;\u003c/span\u003e\u003cspan class=\"site-nav__link-text\"\u003eAbout\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n    \u003c/ul\u003e\n  \u003c/div\u003e\n\u003c/nav\u003e\n\u003ch2 id=\"active-state\"\u003eActive state\u003c/h2\u003e\n\u003cp\u003eCurrent section gets \u003ccode\u003e--base0B\u003c/code\u003e. Hover any pill to see \u003ccode\u003e--base0C\u003c/code\u003e.\u003c/p\u003e\n\u003cnav class=\"site-nav\" aria-label=\"Active nav demo\" style=\"margin: 1rem 0;\"\u003e\n  \u003cdiv class=\"site-nav__inner\"\u003e\n    \u003ca href=\"#\" class=\"site-nav__title\"\u003e\u003cspan class=\"icon site-nav__icon\" aria-hidden=\"true\"\u003e\u0026#xf005;\u003c/span\u003e\u003cspan class=\"site-nav__title-text\"\u003eDemo\u003c/span\u003e\u003c/a\u003e\n    \u003cul class=\"site-nav__menu\"\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eHome\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eProjects\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link is-active\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eBlog\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n      \u003cli class=\"site-nav__item\"\u003e\u003ca href=\"#\" class=\"site-nav__link\"\u003e\u003cspan class=\"site-nav__link-text\"\u003eAbout\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\n    \u003c/ul\u003e\n  \u003c/div\u003e\n\u003c/nav\u003e\n\u003ch2 id=\"responsive\"\u003eResponsive\u003c/h2\u003e\n\u003cdl class=\"info-list\"\u003e\n  \u003cdt\u003e992px\u003c/dt\u003e\u003cdd\u003ePill padding shrinks.\u003c/dd\u003e\n  \u003cdt\u003e768px\u003c/dt\u003e\u003cdd\u003eLink text hides, leaving icon-only pills. Overflows scroll horizontally.\u003c/dd\u003e\n\u003c/dl\u003e\n\u003cp\u003eResize this window to see both states.\u003c/p\u003e\n\u003ch2 id=\"config\"\u003eConfig\u003c/h2\u003e\n\u003cdiv class=\"highlight\"\u003e\u003cpre tabindex=\"0\" class=\"chroma\"\u003e\u003ccode class=\"language-toml\" data-lang=\"toml\"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003eparams\u003c/span\u003e\u003cspan class=\"p\"\u003e]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nx\"\u003etitleIcon\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;terminal\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003emenu\u003c/span\u003e\u003cspan class=\"p\"\u003e]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e[[\u003c/span\u003e\u003cspan class=\"nx\"\u003emenu\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003emain\u003c/span\u003e\u003cspan class=\"p\"\u003e]]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003ename\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;Home\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eurl\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;/\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eweight\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"mi\"\u003e10\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003emenu\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003emain\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003eparams\u003c/span\u003e\u003cspan class=\"p\"\u003e]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"nx\"\u003eicon\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;home\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e[[\u003c/span\u003e\u003cspan class=\"nx\"\u003emenu\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003emain\u003c/span\u003e\u003cspan class=\"p\"\u003e]]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003ename\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;Blog\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eurl\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;/blog/\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eweight\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"mi\"\u003e20\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003emenu\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003emain\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003eparams\u003c/span\u003e\u003cspan class=\"p\"\u003e]\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"nx\"\u003eicon\u003c/span\u003e \u003cspan class=\"p\"\u003e=\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;document\u0026#34;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/div\u003e"
}
