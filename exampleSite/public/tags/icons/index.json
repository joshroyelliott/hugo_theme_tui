     \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"javascript\"\u003e\u0026#xe74e;\u003c/span\u003e\n\n      \u003ccode\u003ejavascript\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"link: U+F0C1\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"link\"\u003e\u0026#xf0c1;\u003c/span\u003e\n\n      \u003ccode\u003elink\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"linkedin: U+F08C\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"linkedin\"\u003e\u0026#xf08c;\u003c/span\u003e\n\n      \u003ccode\u003elinkedin\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"lua: U+E620\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"lua\"\u003e\u0026#xe620;\u003c/span\u003e\n\n      \u003ccode\u003elua\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"mastodon: U+F4F6\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"mastodon\"\u003e\u0026#xf4f6;\u003c/span\u003e\n\n      \u003ccode\u003emastodon\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"phone: U+F095\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"phone\"\u003e\u0026#xf095;\u003c/span\u003e\n\n      \u003ccode\u003ephone\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"privacy: U+F21B\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"privacy\"\u003e\u0026#xf21b;\u003c/span\u003e\n\n      \u003ccode\u003eprivacy\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"python: U+E73C\"\u003e\n      \u003cspan class=\"icon\" aria-hidden=\"true\" data-icon=\"python\"\u003e\u0026#xe73c;\u003c/span\u003e\n\n      \u003ccode\u003epython\u003c/code\u003e\n    \u003c/div\u003e\u003cdiv class=\"icon-grid__cell\" title=\"rss: U+F09E\"\u003e\n      \u003cspa